#!/bin/bash
#  _______   _______
# |  _____| |  ___  |
# | |       | |   | |    Rolando Ramos Torres (@rolodoom)
# | |       | |___| |    http://rolandoramostorres.com
# |_|       |_______|
#  _         _______     
# | |       |  ___  |
# | |       | |   | |    r_git_update
# | |_____  | |___| |    Enhanced git_update script to handle local commits and 
# |_______| |_______|    amend last pushed commit safely
# 
#

# ----------------------------------------
# Display usage/help message
# ----------------------------------------
show_help() {
    cat << EOF
Usage: $(basename $0) [OPTIONS] MESSAGE

Git commit with required message, with options to commit normally or recreate last commit.

OPTIONS:
  -h, --help      Display this help message
  -r, --recommit  Undo last commit and commit again with new message

EXAMPLES:
  $(basename $0) "Commit new changes"
  $(basename $0) -r "Fix last commit message"
EOF
    exit 0
}

# ----------------------------------------
# Display an error message and exit
# ----------------------------------------
error_exit() {
    echo "Error: $1"
    exit 1
}

# ----------------------------------------
# Commit all changes; push only if a remote exists
# ----------------------------------------
commit_new() {
    local message="$1"
    git add -A
    git commit -m "$message"
    
    # Check if any remote exists
    if git remote | grep -q .; then
        git push
        echo "Changes committed and pushed to remote."
    else
        echo "Changes committed locally (no remote detected)."
    fi
}

# ----------------------------------------
# Recreate the last commit with a new message
# (undo last commit locally, create new commit, push with --force)
# ----------------------------------------
recommit_last() {
    local message="$1"
    git reset --soft HEAD~1
    git commit -m "$message"
    git push --force
    echo "Last commit recreated with new message and pushed."
}

# ----------------------------------------
# Main function to parse arguments and execute actions
# ----------------------------------------
main() {
    local recommit=0

    # Show help if no arguments are provided
    if [ $# -eq 0 ]; then
        show_help
    fi

    # Parse options/flags
    while [[ "$1" == -* ]]; do
        case "$1" in
            -h|--help)
                show_help
                ;;
            -r|--recommit)
                recommit=1
                shift
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done

    # The remaining argument must be the commit message
    local message="$1"
    if [ -z "$message" ]; then
        error_exit "Commit message is required!"
    fi

    # Execute the correct action based on the flag
    if [ $recommit -eq 1 ]; then
        recommit_last "$message"
    else
        commit_new "$message"
    fi
}

# ----------------------------------------
# Run main function with all passed arguments
# ----------------------------------------
main "$@"